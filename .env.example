# =============================================================================
# ZenōBank — Variáveis de ambiente globais
# Copie para .env e ajuste. NUNCA commite o .env
# =============================================================================

# Kafka
KAFKA_BROKER_INTERNAL=kafka:29092
KAFKA_BROKER_EXTERNAL=localhost:9092
KAFKA_RETENTION_MS=604800000
KAFKA_DEFAULT_PARTITIONS=3

# Kafdrop (UI)
KAFDROP_PORT=9000

# Zookeeper
ZOOKEEPER_PORT=2181